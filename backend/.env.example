# Server
PORT=5000
NODE_ENV=development

# MongoDB — use a local instance or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/dear-desserts

# JWT Authentication — CHANGE THIS for production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins allowed to access the API
CORS_ORIGIN=http://localhost:5173

# UPI Payment — used for dynamic QR code generation
# Replace with your real UPI ID (e.g. yourname@ybl, yourname@paytm, 9876543210@upi)
UPI_ID=your-upi-id@upi
UPI_PAYEE_NAME=Dear Desserts
